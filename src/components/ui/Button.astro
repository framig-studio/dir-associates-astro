---
// Button.astro
import { cva } from "class-variance-authority";
import { clsx } from "clsx";

const base = clsx(
  "rounded-lg font-medium transition flex gap-2 items-center justify-center",
);
const button = cva(base, {
  variants: {
    variant: {
      primary: "bg-primary text-white",
      secondary: "bg-secondary",
      danger: "bg-red-500 text-white",
      default: "bg-gray-100",
      outline: "border-1 border-gray-800",
      black: "bg-gray-900 text-white",
    },
    size: {
      sm: "px-2 py-1 text-sm",
      md: "px-4 py-2",
      lg: "px-6 py-3 ",
    },
  },
  defaultVariants: {
    variant: "default",
    size: "md",
  },
});

const { variant, size, class: className = "", href, whatsapp } = Astro.props;

// Create WhatsApp URL if whatsapp prop is provided
const getWhatsAppUrl = (phone: string) => {
  const cleanPhone = phone.replace(/\D/g, "");
  return `https://wa.me/${cleanPhone}`;
};

const finalHref = whatsapp ? getWhatsAppUrl(whatsapp) : href;
---

<a
  href={finalHref}
  class={button({ variant, size, class: className })}
  style="box-sizing: border-box;"
>
  <slot />
</a>
