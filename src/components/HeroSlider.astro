---
import { homeData } from "@/data/home";
import slide1 from "@/assets/carousel/slide-1.jpg";
import slide2 from "@/assets/carousel/slide-2.png";
import slide3 from "@/assets/carousel/slide-3.jpg";
import Button from "@/components/ui/Button.astro";

const sliders = homeData.hero.sliders;
const slideImages = [slide1, slide2, slide3];

// Function to style specific text in headers
function styleHeader(header: string) {
  let result = header;

  // Replace "Hukum Terpercaya"
  result = result.replace(
    /Hukum Terpercaya/g,
    '<span class="text-primary underline">Hukum Terpercaya</span>',
  );

  // Replace "Kepailitan & PKPU"
  result = result.replace(
    /Kepailitan & PKPU/g,
    '<span class="text-primary underline">Kepailitan & PKPU</span>',
  );

  // Replace "Bisnis & Aset"
  result = result.replace(
    /Bisnis & Aset/g,
    '<span class="text-primary underline">Bisnis & Aset</span>',
  );

  return result;
}
---

<div id="hero-slider" class="relative overflow-hidden">
  <div
    class="flex transition-transform duration-500 ease-in-out"
    id="slider-container"
  >
    {
      sliders.map((sl, index) => {
        const isReversed = index === 1; // Second slide (index 1) is reversed
        const styledHeader = styleHeader(sl.header);

        return (
          <div class="w-full shrink-0 px-4 sm:px-6 lg:px-8">
            <div
              class={`flex flex-col lg:flex-row justify-between items-center w-full gap-8 lg:gap-12 xl:gap-25 ${
                isReversed ? "lg:flex-row-reverse" : ""
              }`}
            >
              <div class="flex flex-col space-y-6 sm:space-y-8 lg:space-y-10 max-w-full lg:max-w-2xl xl:max-w-3xl">
                <h1
                  class="text-5xl sm:text-5xl md:text-6xl lg:text-6xl font-semibold leading-normal lg:leading-20"
                  set:html={styledHeader}
                />

                <p class="text-sm sm:text-base lg:text-lg text-secondary">
                  {sl.sub_header}
                </p>

                <div class="flex items-center">
                  <Button
                    variant="primary"
                    size="lg"
                    href={sl.href}
                    class="w-full sm:w-auto"
                  >
                    {sl.cta}
                  </Button>
                </div>
              </div>

              <div class="w-full lg:w-auto flex justify-center lg:justify-end mt-8 lg:mt-0">
                <img
                  src={slideImages[index].src}
                  alt={sl.header}
                  class="w-full max-w-sm sm:max-w-md md:max-w-lg lg:h-80 xl:h-96 2xl:h-110 lg:w-auto rounded-2xl lg:rounded-4xl object-cover"
                />
              </div>
            </div>
          </div>
        );
      })
    }
  </div>

  <!-- Indicators -->
  <div
    class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2 z-10"
  >
    {
      sliders.map((_, index) => (
        <button
          class={`w-3 h-3 rounded-full transition-all duration-200 ${
            index === 0 ? "bg-white" : "bg-white/50 hover:bg-white/75"
          }`}
          data-slide={index}
          aria-label={`Go to slide ${index + 1}`}
        />
      ))
    }
  </div>
</div>

<script>
  let currentSlide = 0;
  const totalSlides = 3; // Number of slides from homeData
  let autoSlideInterval: number | undefined;
  const autoSlideDelay = 5000; // 5 seconds

  const sliderContainer = document.getElementById("slider-container");
  const indicators = document.querySelectorAll("[data-slide]");

  function updateSlider() {
    if (!sliderContainer) return;

    // Move from right to left (negative translateX)
    sliderContainer.style.transform = `translateX(-${currentSlide * 100}%)`;

    // Update indicators
    indicators.forEach((indicator, index) => {
      if (index === currentSlide) {
        indicator.classList.remove("bg-white/50", "hover:bg-white/75");
        indicator.classList.add("bg-white");
      } else {
        indicator.classList.remove("bg-white");
        indicator.classList.add("bg-white/50", "hover:bg-white/75");
      }
    });
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    updateSlider();
    resetAutoSlide();
  }

  function prevSlide() {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    updateSlider();
    resetAutoSlide();
  }

  function goToSlide(slideIndex: number) {
    currentSlide = slideIndex;
    updateSlider();
    resetAutoSlide();
  }

  function startAutoSlide() {
    autoSlideInterval = window.setInterval(nextSlide, autoSlideDelay);
  }

  function resetAutoSlide() {
    if (autoSlideInterval !== undefined) {
      clearInterval(autoSlideInterval);
    }
    startAutoSlide();
  }

  // Event listeners for indicators only

  indicators.forEach((indicator, index) => {
    indicator.addEventListener("click", () => goToSlide(index));
  });

  // Pause on hover
  const slider = document.getElementById("hero-slider");
  if (slider) {
    slider.addEventListener("mouseenter", () => {
      if (autoSlideInterval !== undefined) {
        clearInterval(autoSlideInterval);
      }
    });
    slider.addEventListener("mouseleave", startAutoSlide);
  }

  // Start auto-slide
  startAutoSlide();
</script>
