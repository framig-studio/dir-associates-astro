---
import Button from "@/components/ui/Button.astro";
import aboutUsImage from "@/assets/home-about.png";
import dir_logo from "@/assets/dir-svg.svg";
import TextHeader from "@/components/ui/TextHeader.astro";
import { homeData } from "@/data/home.ts";
---

<section id="about-us" class="w-full pt-16 flex justify-center" id="about-us">
  <div class="container flex flex-col gap-8">
    <TextHeader
      text={homeData.aboutUs.header.text}
      boldText={homeData.aboutUs.header.boldText}
    />

    <div
      class="flex flex-col lg:flex-row gap-8 lg:gap-10 justify-between items-center"
    >
      <div class="flex flex-col gap-6 flex-1 text-center lg:text-left">
        <div class="space-y-3">
          <img
            src={dir_logo.src}
            alt="DIR & Associates"
            loading="lazy"
            class="w-auto h-20 mx-auto lg:mx-0"
          />
          <h3 class="sm:text-xl font-semibold text-2xl">
            {homeData.aboutUs.companyName}
          </h3>
          <span
            class="py-1 px-3 rounded-full text-lg inline-block"
            style="background: #0f524416;"
          >
            {homeData.aboutUs.founderName}
          </span>
        </div>

        <div class="text-secondary text-base lg:text-lg space-y-4">
          {homeData.aboutUs.description.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <div class="mt-6">
          <Button
            variant="primary"
            size="lg"
            href={homeData.aboutUs.cta.href}
            class="w-full md:inline-block md:w-fit"
            >{homeData.aboutUs.cta.text}</Button
          >
        </div>
      </div>

      <div class="flex-1 flex justify-center lg:justify-end">
        <img
          src={aboutUsImage.src}
          alt="About Us"
          class="w-full max-w-md lg:max-w-lg h-auto"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
