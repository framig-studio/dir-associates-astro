---
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, Astro.url.origin).href } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="py-4">
  <ol class="flex items-center flex-wrap gap-2">
    {
      items.map((item, index) => (
        <li class="flex items-center">
          {item.href ? (
            <a
              href={item.href}
              class="text-gray-400 hover:underline hover:text-gray-600 transition-colors max-w-36 sm:max-w-none truncate"
            >
              {item.label}
            </a>
          ) : (
            <span class="text-gray-800 max-w-36 sm:max-w-none truncate">
              {item.label}
            </span>
          )}
          {index < items.length - 1 && (
            <span class="text-gray-400 mx-2 shrink-0">/</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbStructuredData)}></script>
