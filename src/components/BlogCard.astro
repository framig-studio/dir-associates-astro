---
export interface Props {
  data: {
    title: string;
    description: string;
    image?: string;
    publish_date?: string;
    slug: string;
  };
}

const { data } = Astro.props;

// Fallback to prevent undefined errors
const cardData = data || {
  title: "Untitled",
  description: "No description available",
  image: "",
  publish_date: "",
  slug: "",
};
---

<div
  class="h-full flex flex-col space-y-5 p-3 hover:bg-gray-100 transition-colors rounded-2xl"
>
  <a href={`/blog/${cardData.slug}`} class="block">
    <div
      class="relative overflow-hidden rounded-2xl bg-gray-100"
      style="height: 200px;"
    >
      {
        cardData.image ? (
          <img
            src={cardData.image}
            alt={cardData.title}
            class="w-full h-full object-cover transition-transform duration-300 hover:scale-115"
            loading="lazy"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-gray-400">
            <svg
              class="w-12 h-12"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
          </div>
        )
      }
    </div>
  </a>

  <a href={`/blog/${cardData.slug}`} class="block">
    <h2
      class="text-2xl font-semibold text-gray-900 hover:text-primary transition-colors"
    >
      {cardData.title}
    </h2>
  </a>

  <div class="flex justify-between gap-8 mt-auto">
    <span>
      {
        cardData.publish_date && (
          <p class="text-gray-500">
            {new Date(cardData.publish_date).toLocaleDateString("id-ID", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })}
          </p>
        )
      }
    </span>

    <div>
      <a
        href={`/blog/${cardData.slug}`}
        class="text-primary hover:text-primary-dark font-medium"
      >
        Baca Selengkapnya
      </a>
    </div>
  </div>
</div>
