---
export interface Props {
  name: string;
  date: Date;
  content: string;
}

const { name, date, content } = Astro.props;

// Function to format date for static build (server-side)
function formatDate(date: Date): string {
  return date.toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<div
  class="h-full flex flex-col space-y-4 p-6 bg-white rounded-2xl hover:shadow-md transition-shadow"
>
  <div class="flex items-start justify-between">
    <div class="flex-1">
      <h3 class="text-lg font-semibold text-gray-900">
        {name}
      </h3>
      <p class="text-sm text-gray-500" data-date={date.toISOString()}>
        {formatDate(date)}
      </p>
    </div>
    <div class="flex gap-1 text-amber-400">
      {
        [...Array(5)].map(() => (
          <svg
            width="16"
            height="16"
            viewBox="0 0 19 18"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M8.26186 0.7496C8.77776 -0.249867 10.2222 -0.249866 10.7381 0.7496L12.651 4.45546C12.853 4.84675 13.232 5.119 13.6709 5.188L17.8268 5.84149C18.9477 6.01773 19.3941 7.37595 18.5921 8.16989L15.6183 11.1137C15.3043 11.4246 15.1595 11.8651 15.2288 12.299L15.8844 16.4087C16.0612 17.5171 14.8926 18.3566 13.8811 17.8478L10.1303 15.9613C9.73424 15.7621 9.26576 15.7621 8.86972 15.9613L5.11895 17.8478C4.10736 18.3566 2.93876 17.5171 3.11559 16.4087L3.77123 12.299C3.84046 11.8651 3.69569 11.4246 3.3817 11.1137L0.407945 8.16989C-0.394074 7.37595 0.0522941 6.01773 1.17316 5.84149L5.32915 5.188C5.76797 5.119 6.14698 4.84675 6.34896 4.45546L8.26186 0.7496Z"
              fill="currentColor"
            />
          </svg>
        ))
      }
    </div>
  </div>

  <p class="text-gray-700 leading-relaxed grow">
    "{content}"
  </p>
</div>

<script>
  // Function to humanize date in Indonesian
  function humanizeDate(dateString: string) {
    const now = new Date();
    const date = new Date(dateString);
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const reviewDate = new Date(
      date.getFullYear(),
      date.getMonth(),
      date.getDate(),
    );

    const diffTime = today.getTime() - reviewDate.getTime();
    const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

    if (diffDays === 0) {
      return "hari ini";
    } else if (diffDays === 1) {
      return "kemarin";
    } else if (diffDays === -1) {
      return "besok";
    } else if (diffDays > 1 && diffDays <= 7) {
      return `${diffDays} hari yang lalu`;
    } else if (diffDays < -1 && diffDays >= -7) {
      return `${Math.abs(diffDays)} hari lagi`;
    } else if (diffDays > 7 && diffDays <= 30) {
      const weeks = Math.floor(diffDays / 7);
      return `${weeks} minggu yang lalu`;
    } else if (diffDays < -7 && diffDays >= -30) {
      const weeks = Math.floor(Math.abs(diffDays) / 7);
      return `${weeks} minggu lagi`;
    } else if (diffDays > 30 && diffDays <= 365) {
      const months = Math.floor(diffDays / 30);
      return `${months} bulan yang lalu`;
    } else if (diffDays < -30 && diffDays >= -365) {
      const months = Math.floor(Math.abs(diffDays) / 30);
      return `${months} bulan lagi`;
    } else if (diffDays > 365) {
      const years = Math.floor(diffDays / 365);
      return `${years} tahun yang lalu`;
    } else {
      const years = Math.floor(Math.abs(diffDays) / 365);
      return `${years} tahun lagi`;
    }
  }

  // Update all date elements on page load
  document.addEventListener("DOMContentLoaded", () => {
    const dateElements = document.querySelectorAll("[data-date]");
    dateElements.forEach((element) => {
      const dateString = element.getAttribute("data-date");
      if (dateString) {
        element.textContent = humanizeDate(dateString);
      }
    });
  });
</script>
