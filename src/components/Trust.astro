---
import { homeData } from "@/data/home.ts";
---

<section
  style="background: #FAF8F3;"
  class="py-8 lg:py-6 flex items-center justify-center"
>
  <div class="grid grid-cols-2 lg:flex lg:flex-row gap-8 lg:gap-20 px-4">
    {
      homeData.trust.stats.map((item) => (
        <div class="flex flex-col lg:flex-row items-center justify-center gap-2 text-center lg:text-left">
          <div class="text-2xl sm:text-xl font-semibold">{item.num}</div>
          <div class="text-base">{item.label}</div>
        </div>
      ))
    }
  </div>
</section>
