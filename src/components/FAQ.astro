---
import { faqData } from "@/data/faq.ts";
---

<section class="w-full py-16 bg-gray-100 pb-24">
  <div class="container mx-auto">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-semibold mb-4">
          {faqData.header}
        </h2>
        <p class="text-secondary text-base">
          {faqData.description}
        </p>
      </div>

      <div class="space-y-4">
        {
          faqData.items.map((item, index: number) => (
            <div class="bg-white rounded-2xl border border-gray-200">
              <button
                class="faq-toggle w-full text-left p-6 flex justify-between items-center cursor-pointer"
                data-index={index}
                aria-expanded="false"
                aria-controls={`faq-answer-${index}`}
              >
                <span class="font-medium text-base lg:text-lg pr-4">
                  {item.question}
                </span>
                <svg
                  class="w-5 h-5 transition-transform duration-200 faq-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </button>

              <div
                id={`faq-answer-${index}`}
                class="overflow-hidden transition-all duration-300 max-h-0"
                aria-hidden="true"
              >
                <div class="p-6 pt-0 text-secondary text-base lg:text-lg leading-relaxed">
                  {item.answer}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  let openIndex = -1;

  function toggleFAQ(index: number) {
    const button = document.querySelector(
      `[data-index="${index}"]`,
    ) as HTMLElement;
    const answer = document.getElementById(
      `faq-answer-${index}`,
    ) as HTMLElement;
    const icon = button?.querySelector(".faq-icon") as HTMLElement;

    // Close previously opened item
    if (openIndex !== -1 && openIndex !== index) {
      const prevButton = document.querySelector(
        `[data-index="${openIndex}"]`,
      ) as HTMLElement;
      const prevAnswer = document.getElementById(
        `faq-answer-${openIndex}`,
      ) as HTMLElement;
      const prevIcon = prevButton?.querySelector(".faq-icon") as HTMLElement;

      if (prevButton) prevButton.setAttribute("aria-expanded", "false");
      if (prevAnswer) prevAnswer.style.maxHeight = "0";
      if (prevIcon) prevIcon.classList.remove("rotate-180");
      if (prevAnswer) prevAnswer.setAttribute("aria-hidden", "true");
    }

    // Toggle current item
    if (openIndex === index) {
      // Close current item
      if (button) button.setAttribute("aria-expanded", "false");
      if (answer) answer.style.maxHeight = "0";
      if (icon) icon.classList.remove("rotate-180");
      if (answer) answer.setAttribute("aria-hidden", "true");
      openIndex = -1;
    } else {
      // Open current item
      if (button) button.setAttribute("aria-expanded", "true");
      if (answer) answer.style.maxHeight = "24rem";
      if (icon) icon.classList.add("rotate-180");
      if (answer) answer.setAttribute("aria-hidden", "false");
      openIndex = index;
    }
  }

  // Add event listeners
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll(".faq-toggle");
    buttons.forEach((button) => {
      button.addEventListener("click", (e) => {
        e.preventDefault();
        const index = parseInt((button as HTMLElement).dataset.index || "0");
        toggleFAQ(index);
      });
    });
  });
</script>
