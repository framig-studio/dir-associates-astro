---
import "@/styles/global.css";
import TopNavigation from "./TopNavigation.astro";
import Footer from "./Footer.astro";
import SEOMetaTags from "@/components/SEOMetaTags.astro";
import Analytics from "@vercel/analytics/astro";

const {
  title = "DIR & Associates - Advokat, Kurator & Pengurus, Pengacara Pajak prestisius.",
  seo,
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
    <link rel="icon" href="/dir-logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {seo && <SEOMetaTags {...seo} />}
    <meta
      name="google-site-verification"
      content="lfkhxKoCsxvFFAFAAwpSxaOO1G3xbehvdjrlu0BCg6w"
    />
  </head>
  <body class="mt-20">
    <TopNavigation />
    <main>
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
