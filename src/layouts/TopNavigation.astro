---
import dir_logo_b from "@/assets/dir-logo.png";
import Button from "@/components/ui/Button.astro";

const menus = [
  {
    label: "Home",
    href: "/",
  },
  {
    label: "Tentang Kami",
    href: "/about-us",
  },
  {
    label: "Layanan",
    href: "/service",
  },
  // {
  //   label: "Tim Kami",
  //   href: "/#team",
  // },
  {
    label: "Portofolio",
    href: "/#portfolio",
  },
  {
    label: "Blog",
    href: "/blog",
  },
];
---

<script>
  // Navigation functionality
  document.addEventListener("DOMContentLoaded", () => {
    const navbar = document.getElementById("navbar");
    const navLinks = document.querySelectorAll(".nav-link");
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    // Add shadow on scroll
    const addShadowOnScroll = () => {
      if (navbar && window.scrollY > 10) {
        navbar.classList.add("shadow-md");
      } else if (navbar) {
        navbar.classList.remove("shadow-md");
      }
    };

    // Initial check and scroll event listener
    addShadowOnScroll();
    window.addEventListener("scroll", addShadowOnScroll);

    // Mobile menu toggle
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
        mobileMenu.classList.toggle("flex");
      });

      // Close mobile menu when clicking on links
      mobileMenu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
          mobileMenu.classList.remove("flex");
        });
      });
    }

    // Smooth scroll for hash links
    navLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (href?.includes("#") && window.location.pathname === "/") {
          e.preventDefault();
          const targetId = href.substring(href.lastIndexOf("#") + 1);
          const target = document.getElementById(targetId);

          if (target && navbar) {
            const offset = navbar.offsetHeight;
            window.scrollTo({
              top: target.offsetTop - offset,
              behavior: "smooth",
            });
            history.pushState(null, "", href);
          }
        }
      });
    });

    // Handle initial hash
    if (window.location.hash) {
      const targetId = window.location.hash.substring(1);
      const target = document.getElementById(targetId);
      if (target && navbar) {
        setTimeout(() => {
          window.scrollTo({
            top: target.offsetTop - navbar.offsetHeight,
            behavior: "smooth",
          });
        }, 100);
      }
    }
  });
</script>

<header>
  <nav
    class="bg-white/80 backdrop-blur-3xl fixed top-0 w-full z-50 outline-none"
    id="navbar"
  >
    <div class="container mx-auto">
      <div
        class="flex items-center justify-between h-20 transition-all duration-300"
        id="navbar-inner"
      >
        <div class="logo flex gap-5 items-center">
          <img
            src={dir_logo_b.src}
            alt="DIR & Associates"
            id="navbar-logo"
            class="h-10 transition-all duration-300"
          />
          <span
            id="brand"
            class="font-semibold text-xl transition-all duration-300"
            >DIR & ASSOCIATES</span
          >
        </div>

        <!-- Desktop Menu -->
        <div class="hidden md:flex menu">
          <ul class="flex space-x-2 items-center">
            {
              menus.map((menu) => (
                <li>
                  <a
                    href={menu.href}
                    class="nav-link px-4 py-2 font-medium rounded-md transition-all duration-300 hover:bg-gray-100"
                    data-target={menu.href}
                  >
                    {menu.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Desktop CTA -->
        <div class="hidden md:block">
          <Button whatsapp="+62 822-918-789" variant="outline"
            >Mari Bicara
            <svg
              width="8"
              height="8"
              viewBox="0 0 8 8"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M0.714294 0.714287H6.42858M6.42858 0.714287V6.42857M6.42858 0.714287L0.714294 6.42857"
                stroke="currentColor"
                stroke-width="1.42857"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </Button>
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="md:hidden p-2 rounded-lg hover:bg-gray-200 transition-colors"
          aria-label="Toggle mobile menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div
        id="mobile-menu"
        class="hidden md:hidden flex-col bg-white border-t border-gray-200 absolute top-full left-0 right-0 shadow-lg"
      >
        <div class="container mx-auto py-4 space-y-2">
          {
            menus.map((menu) => (
              <a
                href={menu.href}
                class="nav-link block px-4 py-3 rounded-lg transition-all duration-300 hover:bg-gray-100 text-center"
                data-target={menu.href}
              >
                {menu.label}
              </a>
            ))
          }
          <Button whatsapp="+62 822-918-789" variant="outline"
            >Mari Bicara
            <svg
              width="8"
              height="8"
              viewBox="0 0 8 8"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M0.714294 0.714287H6.42858M6.42858 0.714287V6.42857M6.42858 0.714287L0.714294 6.42857"
                stroke="currentColor"
                stroke-width="1.42857"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </Button>
        </div>
      </div>
    </div>
  </nav>
</header>
