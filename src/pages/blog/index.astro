---
import TextHeader from "@/components/ui/TextHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import BlogCard from "@/components/BlogCard.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

const posts = await getCollection("blog");
---

<Layout>
  <div
    class="w-full flex flex-col items-center justify-center py-16 gap-16 mt-16"
  >
    <div class="container flex flex-col items-center justify-center gap-8">
      <div
        class="flex items-center gap-3 bg-gray-100 py-1 px-2 sm:px-6 rounded-full max-w-md w-full mx-4 sm:mx-0"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 25"
          ><path
            fill="currentColor"
            fill-rule="evenodd"
            d="M11.25 2.75C6.142 2.75 2 6.89 2 11.998s4.142 9.248 9.25 9.248a9.2 9.2 0 0 0 5.987-2.198l3.481 3.48a.75.75 0 1 0 1.06-1.06l-3.48-3.48a9.2 9.2 0 0 0 2.202-5.99c0-5.108-4.142-9.248-9.25-9.248M3.5 11.998a7.75 7.75 0 0 1 7.75-7.748a7.749 7.749 0 1 1 0 15.496a7.75 7.75 0 0 1-7.75-7.748"
            clip-rule="evenodd"></path></svg
        >
        <input
          type="text"
          id="search-input"
          placeholder="Cari artikel disini"
          class="border-none outline-none py-3 bg-transparent flex-1 min-w-0"
        />
      </div>

      <TextHeader
        text="Silahkan Membaca"
        boldText="Artikel Terbaru Dari Kami"
      />
    </div>

    <div
      id="blog-grid"
      class="container grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
    >
      {posts.map((post) => <BlogCard data={post.data} />)}
    </div>

    <div id="no-results" class="container hidden">
      <p class="text-center text-gray-500 py-8">
        Tidak ada artikel yang ditemukan.
      </p>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById(
    "search-input",
  ) as HTMLInputElement;
  const blogGrid = document.getElementById("blog-grid");
  const noResults = document.getElementById("no-results");

  if (searchInput && blogGrid && noResults) {
    const allCards = blogGrid.children;

    searchInput.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement;
      const searchTerm = target.value.toLowerCase();
      let hasResults = false;

      Array.from(allCards).forEach((card) => {
        const cardElement = card as HTMLElement;
        const titleElement = card.querySelector("h2");
        if (titleElement) {
          const title = titleElement.textContent?.toLowerCase() || "";
          if (title.includes(searchTerm)) {
            cardElement.style.display = "";
            hasResults = true;
          } else {
            cardElement.style.display = "none";
          }
        }
      });

      if (hasResults) {
        blogGrid.classList.remove("hidden");
        noResults.classList.add("hidden");
      } else {
        blogGrid.classList.add("hidden");
        noResults.classList.remove("hidden");
      }
    });
  }
</script>
