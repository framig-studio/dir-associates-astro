---
import Layout from "@/layouts/Layout.astro";
import AboutUs from "./home/components/AboutUs.astro";
import Hero from "./home/components/Hero.astro";
import Service from "./home/components/Service.astro";
import Team from "./home/components/Team.astro";
import Trust from "./home/components/Trust.astro";
import StructuredData from "@/components/StructuredData.astro";
import FAQ from "@/components/FAQ.astro";

const seo = {
  title:
    "DIR & Associates - Advokat, Kurator & Pengurus, Pengacara Pajak Surabaya",
  description:
    "DIR & Associates adalah firma hukum terpercaya di Surabaya yang menyediakan layanan advokat, kurator & pengurus, pengacara pajak, dan mediator untuk perusahaan dan individu di seluruh Indonesia.",
  keywords:
    "pengacara kepailitan indonesia, advokat surabaya, kurator dan pengurus, pengacara pajak, firma hukum, layanan hukum, mediator, PKPU, DIR & Associates, Dwi Oktorianto",
  type: "website",
  image: "/dir-logo.png",
};
---

<Layout title={seo.title} seo={seo}>
  <StructuredData
    type="LegalService"
    name="DIR & Associates"
    description="DIR & Associates adalah firma hukum terpercaya di Surabaya yang menyediakan layanan advokat, kurator & pengurus, pengacara pajak, dan mediator untuk perusahaan dan individu di seluruh Indonesia."
    url="https://dir-associates.com"
    telephone="+62 822-918-789"
    email="dirlaw@gmail.com"
    image="/dir-logo.png"
    openingHours={["Mo-Fr 09:00-17:00"]}
    priceRange="$$"
  />
  <div class="flex flex-col">
    <Hero />
    <Trust />
    <AboutUs />
    <Service />
    <FAQ />
    <Team />
  </div>
</Layout>
