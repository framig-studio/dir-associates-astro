---
import TextHeader from "@/components/ui/TextHeader.astro";
import Layout from "@/layouts/Layout.astro";
import PortfolioCard from "@/components/PortfolioCard.astro";

// Gallery path variable
const seo = {
  title: "Portofolio",
  description:
    "Lihat portofolio unggulan DIR & Associates - firma hukum terpercaya di Surabaya dengan berbagai kasus hukum yang telah berhasil ditangani.",
  keywords:
    "portofolio pengacara, kasus hukum surabaya, firma hukum terpercaya, advokat profesional, DIR & Associates portofolio",
  type: "website",
  image: "/dir-logo.png",
};

const galleryPath = "/gallery";

// Portfolio data - using gallery assets
const portfolioItems = [
  `${galleryPath}/gallery-1.jpg`,
  `${galleryPath}/gallery-2.jpg`,
  `${galleryPath}/gallery-3.jpg`,
  `${galleryPath}/gallery-4.jpg`,
  `${galleryPath}/gallery-5.jpg`,
  `${galleryPath}/gallery-6.jpg`,
  `${galleryPath}/gallery-7.jpg`,
  `${galleryPath}/gallery-8.jpg`,
  `${galleryPath}/gallery-9.jpg`,
  `${galleryPath}/gallery-10.jpg`,
  `${galleryPath}/gallery-12.jpg`,
  `${galleryPath}/gallery-14.jpg`,
  `${galleryPath}/gallery-16.jpg`,
  `${galleryPath}/gallery-17.jpg`,
  `${galleryPath}/gallery-18.jpg`,
  `${galleryPath}/gallery-19.jpg`,
  `${galleryPath}/gallery-20.jpg`,
  `${galleryPath}/gallery-21.jpg`,
  `${galleryPath}/gallery-22.jpg`,
  `${galleryPath}/gallery-23.jpg`,
  `${galleryPath}/gallery-24.jpg`,
];
---

<Layout title={seo.title} seo={seo}>
  <div
    class="w-full flex flex-col items-center justify-center py-16 gap-16 mt-16 mb-20"
  >
    <div class="container flex flex-col items-center justify-center gap-8">
      <TextHeader text="Lihat Portofolio" boldText="Unggulan Kami" />
    </div>

    <div
      id="portfolio-grid"
      class="container grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
    >
      {portfolioItems.map((image) => <PortfolioCard image={image} />)}
    </div>
  </div>
</Layout>
