---
import Button from "@/components/ui/Button.astro";
import TextHeader from "@/components/ui/TextHeader.astro";
import teamImage from "@/assets/team.png";
---

<div class="w-full flex justify-center" id="team">
  <div class="container flex flex-col items-center gap-10 py-16 pb-0">
    <div class="space-y-3">
      <TextHeader text="Mari Bertemu" boldText="Tim Professional Dari Kami" />
      <div class="text-secondary text-center text-sm sm:text-base">
        Layanan kami 24/7 hanya untuk membantu memberikan solusi untuk anda
      </div>
    </div>

    <Button href="/contact" variant="primary" size="lg"> Hubungi Kami </Button>

    <img src={teamImage.src} alt="Team" class="w-full max-w-2xl h-auto" />
  </div>
</div>
