---
const data = [
  {
    num: "99%",
    label: "Kepuasan Client",
  },
  {
    num: "100+",
    label: "Kasus Ditangani",
  },
  {
    num: "9th+",
    label: "Pengalaman Professional",
  },
  {
    num: "6",
    label: "Profesional Tim",
  },
];
---

<div class="bg-gray-100 py-8 lg:py-5 flex items-center justify-center">
  <div class="grid grid-cols-2 lg:flex lg:flex-row gap-8 lg:gap-20 px-4">
    {
      data.map((item) => (
        <div class="flex flex-col lg:flex-row items-center justify-center gap-2 text-center lg:text-left">
          <div class="text-2xl sm:text-3xl font-semibold">{item.num}</div>
          <div class="text-sm sm:text-base">{item.label}</div>
        </div>
      ))
    }
  </div>
</div>
