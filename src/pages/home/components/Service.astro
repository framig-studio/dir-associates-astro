---
import TextHeader from "@/components/ui/TextHeader.astro";
import { service } from "@/data/service";
import law_icon from "@/assets/law-icon.svg";
---

<div class="w-full bg-gray-50 flex justify-center" id="service">
  <div class="container flex flex-col items-center gap-10 py-16">
    <div class="space-y-3">
      <TextHeader
        text="Solusi Penyelesaian"
        boldText="Masalah Hukum yang Efisien"
      />
      <div class="text-secondary text-center">
        Kami menyediakan berbagai layanan hukum untuk membantu Anda
        menyelesaikan masalah hukum dengan efisien.
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        service.map((item) => (
          <div class="bg-white p-6 rounded-2xl flex flex-col gap-5">
            <div class="flex gap-5 items-center">
              <img src={law_icon.src} alt="Law Icon" />
              <h2 class="text-xl font-semibold mb-2">{item.title}</h2>
            </div>

            <p class="text-secondary">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</div>
