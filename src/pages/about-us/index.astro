---
import Layout from "@/layouts/Layout.astro";
import about_us_vision from "@/assets/about-us-vision.jpg";
import about_us_mission from "@/assets/about-us-mission.jpg";
import Button from "@/components/ui/Button.astro";
import Team from "./team.astro";
import { aboutData } from "@/data/about.ts";

const seo = {
  title: "Tentang Kami",
  description:
    "DIR & Associates adalah firma hukum terpercaya di Surabaya yang menyediakan layanan advokat, kurator & pengurus, pengacara pajak, dan mediator untuk perusahaan dan individu di seluruh Indonesia.",
  keywords:
    "advokat surabaya, kurator dan pengurus, pengacara pajak, firma hukum, layanan hukum, mediator, PKPU, DIR & Associates, Dwi Oktorianto",
  type: "website",
  image: "/dir-logo.png",
};
---

<Layout title={seo.title} seo={seo}>
  <div
    class="container flex flex-col items-center mx-auto my-6 gap-20"
    style="margin-top: 100px;"
  >
    <section id="hero" class="flex items-center gap-12 w-full justify-center">
      <div class="flex flex-col gap-8 max-w-4xl">
        <h1 class="text-5xl font-medium text-center">
          {aboutData.hero.title}
        </h1>

        <p class="text-lg text-secondary text-center">
          {aboutData.hero.description}
        </p>

        <div class="flex justify-center gap-4">
          <Button href={aboutData.hero.cta.href} variant="primary" size="lg">
            {aboutData.hero.cta.text}
          </Button>
        </div>
      </div>
    </section>

    <div class="flex flex-col gap-10">
      <section id="nest" class="container p-10 bg-gray-100 rounded-xl">
        <p class="text-center text-xl">
          "{aboutData.quote}"
        </p>
      </section>

      <section id="stats" class="grid grid-cols-2 md:grid-cols-4 gap-8 w-full">
        {
          aboutData.stats.map((item) => (
            <div class="flex flex-col items-center gap-2 p-5 bg-gray-100 rounded-xl">
              <span class="text-4xl font-bold">{item.num}</span>
              <span class="text-base text-secondary">{item.label}</span>
            </div>
          ))
        }
      </section>
    </div>

    <section
      id="vision-mission"
      class="max-w-6xl mx-auto flex flex-col gap-12 md:gap-16 my-16"
    >
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16">
        <img
          src={about_us_vision.src}
          alt="Vision & Mission"
          class="w-full md:w-1/2 h-auto rounded-2xl"
        />
        <div class="flex flex-col gap-5 w-full md:w-1/2">
          <h3 class="text-3xl md:text-4xl font-medium">
            {aboutData.visionMission.vision.title}
          </h3>
          <p class="text-secondary text-base/relaxed">
            {aboutData.visionMission.vision.description}
          </p>
        </div>
      </div>

      <div
        class="flex flex-col md:flex-row-reverse items-center gap-8 md:gap-16"
      >
        <img
          src={about_us_mission.src}
          alt="Vision & Mission"
          class="w-full md:w-1/2 h-auto rounded-2xl"
        />
        <div class="flex flex-col gap-5 w-full md:w-1/2">
          <h3 class="text-3xl md:text-4xl font-medium">
            {aboutData.visionMission.mission.title}
          </h3>
          {
            aboutData.visionMission.mission.items.map((item) => (
              <p class="text-secondary text-base/relaxed">
                <strong>{item.split(" ").slice(0, 2).join(" ")}</strong>{" "}
                {item.split(" ").slice(2).join(" ")}
              </p>
            ))
          }
        </div>
      </div>
    </section>

    <Team />
  </div>
</Layout>
