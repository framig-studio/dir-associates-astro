---
import { aboutData } from "@/data/about.ts";
---

<section id="team">
  <div class="container max-w-6xl mx-auto flex flex-col gap-8">
    <div class="flex flex-col gap-4">
      <h2 class="text-4xl font-medium">{aboutData.team.header}</h2>
      <p class="text-base text-secondary">
        {aboutData.team.description}
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        aboutData.team.members.map((item) => (
          <div class="flex flex-col gap-4">
            {/* image container */}
            <div class="w-full aspect-square rounded-2xl overflow-hidden">
              <img
                src={item.image.src}
                alt={item.name}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="text-2xl font-medium">{item.name}</h3>
            <p class="text-base text-secondary">{item.level}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
