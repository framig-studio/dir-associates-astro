---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import Services from "@/pages/service/Services.astro";
import FAQ from "@/components/FAQ.astro";
import TestimonialSection from "@/components/TestimonialSection.astro";
import Rating from "@/components/Rating.astro";

const seo = {
  title: "Layanan",
  description:
    "DIR & Associates adalah firma hukum terpercaya di Surabaya yang menyediakan layanan advokat, kurator & pengurus, pengacara pajak, dan mediator untuk perusahaan dan individu di seluruh Indonesia.",
  keywords:
    "advokat surabaya, kurator dan pengurus, pengacara pajak, firma hukum, layanan hukum, mediator, PKPU, DIR & Associates, Dwi Oktorianto",
  type: "website",
  image: "/dir-logo.png",
};
---

<Layout title={seo.title} seo={seo}>
  <div class="container flex flex-col items-center mx-auto my-16 gap-20">
    <section
      id="hero"
      class="flex flex-col items-center gap-12 w-full justify-between pt-10"
    >
      <div class="flex flex-col gap-5 lg:max-w-4xl">
        <h1 class="text-4xl font-medium text-center">
          Solusi Penyelesaian Masalah Hukum yang Efisien
        </h1>
        <p class="text-secondary text-center text-lg">
          Kami menyediakan berbagai layanan hukum untuk membantu Anda
          menyelesaikan masalah hukum dengan efisien.
        </p>
      </div>
      <div>
        <Button whatsapp="+62 822-918-789" variant="primary" size="lg">
          Konsultasi Gratis Sekarang
        </Button>
      </div>
    </section>
    <Services />

    <Rating />
  </div>

  <FAQ />
  <TestimonialSection />
</Layout>
