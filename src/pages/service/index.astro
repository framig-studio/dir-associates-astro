---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import FAQ from "@/components/FAQ.astro";
import TestimonialSection from "@/components/TestimonialSection.astro";
import Rating from "@/components/Rating.astro";
import { serviceData } from "@/data/service";

const seo = {
  title: "Layanan",
  description:
    "DIR & Associates adalah firma hukum terpercaya di Surabaya yang menyediakan layanan advokat, kurator & pengurus, pengacara pajak, dan mediator untuk perusahaan dan individu di seluruh Indonesia.",
  keywords:
    "advokat surabaya terpercaya 2024, konsultan hukum surabaya, kurator pengurus profesional, pengacara kepailitan surabaya, firma hukum terbaik surabaya, layanan hukum lengkap, mediator bersertifikat, PKPU penundaan utang, konsultasi hukum online, DIR & Associates, Dwi Oktorianto, jasa hukum perusahaan",
  type: "website",
  image: "/dir-logo.png",
};
---

<Layout title={seo.title} seo={seo}>
  <div class="container flex flex-col items-center mx-auto my-16 gap-20">
    <section
      id="hero"
      class="flex flex-col items-center gap-12 w-full justify-between pt-10"
    >
      <div class="flex flex-col gap-5 lg:max-w-4xl">
        <h1 class="text-4xl font-medium text-center">
          {serviceData.hero.title}
        </h1>
        <p class="text-secondary text-center text-lg">
          {serviceData.hero.description}
        </p>
      </div>
      <div>
        <Button href={serviceData.hero.cta.href} variant="primary" size="lg">
          {serviceData.hero.cta.text}
        </Button>
      </div>
    </section>

    <Rating />
  </div>

  <FAQ />
  <TestimonialSection />
</Layout>
